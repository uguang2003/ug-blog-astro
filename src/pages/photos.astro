---
/**
 * @description: 照片墙。从后端 API 拉取全部图片，初始 24 张，滚动到底部自动加载下一批；
 *               卡片风格与现有博客统一（圆角 + 深色半透明背景），点击图片打开 lightbox 看原图。
 * @author: UG - 一个斗码大陆苦逼的三段码之气的少年，并没有神秘戒指中码老的帮助，但总有一天，我会成为斗码大陆中码帝一样的存在。三十年河东，三十年河西，莫欺少年穷。
 * @date: 2026-04-25
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import { fetchAllPictures } from "../lib/api";

const pictures = await fetchAllPictures();
const PAGE_SIZE = 24;
---

<BaseLayout title="照片墙 | UG" description="UG 的生活照片记录">
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero title="照片墙" tagline="一张照片，一段记忆。" align="start" />
      <p class="hint">共 <strong>{pictures.length}</strong> 张照片</p>
      <div class="grid" id="photo-grid" data-page-size={PAGE_SIZE}>
        {
          pictures.map((p, idx) => (
            <figure
              class="card"
              data-idx={idx}
              data-src={p.pictureAddress ?? ""}
              data-name={p.pictureName ?? ""}
              data-time={p.pictureTime ?? ""}
              data-desc={p.pictureDescription ?? ""}
              hidden={idx >= PAGE_SIZE ? true : undefined}
            >
              {p.pictureAddress && (
                <img
                  src={p.pictureAddress}
                  alt={p.pictureName ?? ""}
                  loading="lazy"
                  decoding="async"
                />
              )}
              <figcaption>
                <h3>{p.pictureName ?? "(未命名)"}</h3>
                {p.pictureTime && <p class="time">{p.pictureTime}</p>}
              </figcaption>
            </figure>
          ))
        }
      </div>
      <!-- 无限滚动哨兵 -->
      <div id="scroll-sentinel" class="sentinel"></div>
      <p id="scroll-status" class="status"></p>
    </main>
  </div>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" hidden>
    <button class="lb-close" id="lb-close" aria-label="关闭">×</button>
    <button class="lb-nav lb-prev" id="lb-prev" aria-label="上一张">‹</button>
    <button class="lb-nav lb-next" id="lb-next" aria-label="下一张">›</button>
    <figure class="lb-figure">
      <img id="lb-img" alt="" />
      <figcaption id="lb-caption">
        <h4 id="lb-name"></h4>
        <p id="lb-time"></p>
        <p id="lb-desc"></p>
      </figcaption>
    </figure>
  </div>
</BaseLayout>

<script>
  const grid = document.getElementById("photo-grid");
  const sentinel = document.getElementById("scroll-sentinel");
  const status = document.getElementById("scroll-status");
  const lightbox = document.getElementById("lightbox");
  const lbImg = document.getElementById("lb-img") as HTMLImageElement | null;
  const lbName = document.getElementById("lb-name");
  const lbTime = document.getElementById("lb-time");
  const lbDesc = document.getElementById("lb-desc");
  const lbClose = document.getElementById("lb-close");
  const lbPrev = document.getElementById("lb-prev");
  const lbNext = document.getElementById("lb-next");

  if (grid && sentinel && status && lightbox && lbImg && lbName && lbTime && lbDesc) {
    const pageSize = Number(grid.dataset.pageSize ?? 24);
    const cards = Array.from(grid.querySelectorAll<HTMLElement>(".card"));
    let visible = Math.min(pageSize, cards.length);
    let currentIdx = -1;

    const updateStatus = () => {
      if (visible >= cards.length) {
        status.textContent = `已展示全部 ${cards.length} 张`;
      } else {
        status.textContent = `${visible} / ${cards.length}`;
      }
    };

    const loadNext = () => {
      if (visible >= cards.length) return;
      const next = Math.min(visible + pageSize, cards.length);
      for (let i = visible; i < next; i++) cards[i].hidden = false;
      visible = next;
      updateStatus();
      if (visible >= cards.length) observer.unobserve(sentinel);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) loadNext();
        }
      },
      { rootMargin: "300px 0px" },
    );
    observer.observe(sentinel);
    updateStatus();

    // Lightbox
    const openAt = (idx: number) => {
      if (idx < 0 || idx >= cards.length) return;
      currentIdx = idx;
      const card = cards[idx];
      const src = card.dataset.src ?? "";
      const name = card.dataset.name ?? "";
      const time = card.dataset.time ?? "";
      const desc = card.dataset.desc ?? "";
      if (!src) return;
      lbImg.src = src;
      lbImg.alt = name;
      lbName.textContent = name || "(未命名)";
      lbTime.textContent = time;
      lbDesc.textContent = desc;
      lightbox.hidden = false;
      document.body.style.overflow = "hidden";
    };

    const close = () => {
      lightbox.hidden = true;
      lbImg.src = "";
      document.body.style.overflow = "";
      currentIdx = -1;
    };

    cards.forEach((card, idx) => {
      card.addEventListener("click", () => openAt(idx));
    });

    lbClose?.addEventListener("click", close);
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) close();
    });
    lbPrev?.addEventListener("click", (e) => {
      e.stopPropagation();
      openAt((currentIdx - 1 + cards.length) % cards.length);
    });
    lbNext?.addEventListener("click", (e) => {
      e.stopPropagation();
      openAt((currentIdx + 1) % cards.length);
    });
    document.addEventListener("keydown", (e) => {
      if (lightbox.hidden) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowLeft")
        openAt((currentIdx - 1 + cards.length) % cards.length);
      else if (e.key === "ArrowRight")
        openAt((currentIdx + 1) % cards.length);
    });
  }
</script>

<style>
  .hint {
    color: var(--gray-300);
    font-size: var(--text-sm);
  }

  .grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 50em) {
    .grid { grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  }
  @media (min-width: 75em) {
    .grid { grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  }

  /* 与博客卡片同源：subtle 渐变背景 + 灰色边框 + 阴影 */
  .card {
    position: relative;
    margin: 0;
    overflow: hidden;
    cursor: zoom-in;
    border-radius: 0.75rem;
    background: var(--gradient-subtle);
    border: 1px solid var(--gray-800);
    box-shadow: var(--shadow-sm);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .card[hidden] { display: none; }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent-regular);
  }

  .card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .card:hover img {
    transform: scale(1.04);
  }

  /* 标题/时间 overlay 在图片左下，与博客卡片标题徽章风格统一 */
  figcaption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 2rem 0.875rem 0.75rem;
    background: linear-gradient(to top, rgba(15, 14, 23, 0.92) 0%, rgba(15, 14, 23, 0.5) 55%, transparent 100%);
    color: var(--gray-0);
    pointer-events: none;
  }

  figcaption h3 {
    margin: 0;
    font-family: var(--font-brand);
    font-size: var(--text-sm);
    line-height: 1.3;
    font-weight: 600;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .time {
    margin: 0.2rem 0 0;
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.88);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
  }

  .sentinel {
    height: 1px;
  }

  .status {
    text-align: center;
    color: var(--gray-400);
    font-size: var(--text-xs);
    margin-top: 1rem;
    padding-bottom: 2rem;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.2s ease;
  }
  .lightbox[hidden] { display: none; }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .lb-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #lb-img {
    max-width: 92vw;
    max-height: 78vh;
    object-fit: contain;
    border-radius: 0.5rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
  }

  #lb-caption {
    position: fixed;
    left: 50%;
    bottom: 1.25rem;
    transform: translateX(-50%);
    text-align: center;
    color: #fff;
    max-width: min(80ch, 92vw);
    padding: 0.5rem 1rem;
  }

  #lb-caption h4 {
    margin: 0;
    font-size: var(--text-md);
    font-weight: 600;
    color: #fff;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7);
  }

  #lb-caption p {
    margin: 0.2rem 0 0;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7);
  }
  #lb-caption p:empty { display: none; }

  .lb-close, .lb-nav {
    position: fixed;
    border: 0;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease;
    backdrop-filter: blur(6px);
  }

  .lb-close {
    top: 1.5rem;
    right: 1.5rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    font-size: 1.6rem;
    line-height: 1;
  }

  .lb-nav {
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    font-size: 2rem;
    line-height: 1;
  }
  .lb-prev { left: 1.5rem; }
  .lb-next { right: 1.5rem; }

  .lb-close:hover, .lb-nav:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 50em) {
    .lb-nav { width: 40px; height: 40px; font-size: 1.5rem; }
    .lb-prev { left: 0.5rem; }
    .lb-next { right: 0.5rem; }
    .lb-close { top: 0.75rem; right: 0.75rem; }
  }
</style>
