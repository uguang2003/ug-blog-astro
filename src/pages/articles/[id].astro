---
/**
 * @description: 文章详情页。Build 时按 id 静态生成；用 marked 把后端返回的 Markdown 转为 HTML。
 * @author: UG - 一个斗码大陆苦逼的三段码之气的少年，并没有神秘戒指中码老的帮助，但总有一天，我会成为斗码大陆中码帝一样的存在。三十年河东，三十年河西，莫欺少年穷。
 * @date: 2026-04-25
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Icon from "../../components/Icon.astro";
import Pill from "../../components/Pill.astro";
import Comment from "../../components/Comment.astro";
import { fetchAllBlogs, fetchBlogById, type BlogDetail } from "../../lib/api";
import { renderMarkdown } from "../../lib/markdown";

export async function getStaticPaths() {
  const list = await fetchAllBlogs();
  const details = await Promise.all(
    list.map(async (b) => {
      try {
        const detail = await fetchBlogById(b.id);
        return { params: { id: String(b.id) }, props: { blog: detail } };
      } catch (err) {
        console.warn(`[articles/[id]] 跳过 id=${b.id}:`, (err as Error).message);
        return null;
      }
    }),
  );
  return details.filter(Boolean) as { params: { id: string }; props: { blog: BlogDetail } }[];
}

const { blog } = Astro.props as { blog: BlogDetail };
const html = await renderMarkdown(blog.content);
const tags = [blog.type?.name, blog.flag].filter(Boolean) as string[];
const dateText = blog.createTime
  ? new Date(blog.createTime).toLocaleDateString("zh-CN")
  : "";
---

<BaseLayout
  title={blog.title ?? "文章"}
  description={blog.description ?? ""}
>
  <div class="stack gap-20">
    <div class="stack gap-15">
      <header>
        <div class="wrapper stack gap-2">
          <a class="back-link" href="/articles/">
            <Icon icon="arrow-left" /> 文章
          </a>
          <Hero title={blog.title ?? ""} align="start">
            <div class="details">
              <div class="tags">
                {tags.map((t) => <Pill>{t}</Pill>)}
              </div>
              <p class="description">{blog.description}</p>
              <p class="meta">
                {dateText}
                {typeof blog.views === "number" && (
                  <span class="views">· {blog.views} 阅读</span>
                )}
              </p>
            </div>
          </Hero>
        </div>
      </header>
      <main class="wrapper">
        <div class="stack gap-10 content">
          {blog.firstPicture && (
            <img src={blog.firstPicture} alt={blog.title ?? ""} />
          )}
          <div class="content article-body" set:html={html}></div>
          <Comment />
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  header {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--gray-800);
  }
  .back-link { display: none; }

  .details {
    display: flex;
    flex-direction: column;
    padding: 0.5rem;
    gap: 1rem;
    align-items: center;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .description {
    font-size: var(--text-lg);
    max-width: 54ch;
  }

  .meta { color: var(--gray-300); font-size: var(--text-sm); }
  .views { margin-left: 0.4em; }

  .content {
    max-width: 75ch;
    margin-inline: auto;
  }

  .article-body :global(*) {
    margin-top: 1rem;
  }

  .article-body :global(h1),
  .article-body :global(h2),
  .article-body :global(h3),
  .article-body :global(h4),
  .article-body :global(h5) {
    margin: 1.5rem 0;
    line-height: 1.3;
  }

  .article-body :global(img) {
    border-radius: 1rem;
    box-shadow: var(--shadow-sm);
    background: var(--gradient-subtle);
    border: 1px solid var(--gray-800);
    max-width: 100%;
    height: auto;
  }

  .article-body :global(blockquote) {
    font-size: var(--text-lg);
    font-family: var(--font-brand);
    font-weight: 600;
    line-height: 1.4;
    padding-inline-start: 1.5rem;
    border-inline-start: 0.25rem solid var(--accent-dark);
    color: var(--gray-0);
  }

  .article-body :global(pre) {
    background: var(--gray-999);
    border: 1px solid var(--gray-800);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
  }

  .article-body :global(code) {
    background: var(--gray-900);
    padding: 0.1em 0.3em;
    border-radius: 0.25em;
    font-size: 0.9em;
  }

  .article-body :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .back-link,
  .article-body :global(a) {
    text-decoration: 1px solid underline transparent;
    text-underline-offset: 0.25em;
    transition: text-decoration-color var(--theme-transition);
  }

  .back-link:hover,
  .back-link:focus,
  .article-body :global(a:hover),
  .article-body :global(a:focus) {
    text-decoration-color: currentColor;
  }

  @media (min-width: 50em) {
    .back-link { display: block; align-self: flex-start; }
    .details { flex-direction: row; gap: 2.5rem; align-items: flex-end; }
    .article-body :global(blockquote) { font-size: var(--text-2xl); }
  }
  @media (max-width: 50em) {
    .article-body :global(h1),
    .article-body :global(h2),
    .article-body :global(h3) { font-size: var(--text-lg); }
    .article-body :global(p),
    .article-body :global(ul) { width: 90vw; overflow: hidden; }
  }
</style>
